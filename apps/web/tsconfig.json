{
  "extends": "@template/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@template/auth": ["../../packages/auth/src/index.ts"],
      "@template/auth/*": ["../../packages/auth/src/*"],
      "@template/ui": ["../../packages/ui/src/index.ts"],
      "@template/ui/*": ["../../packages/ui/src/*"],
      "@template/api": ["../../packages/api/src/index.ts"],
      "@template/api/*": ["../../packages/api/src/*"],
      "@template/database": ["../../packages/database/src/index.ts"],
      "@template/database/*": ["../../packages/database/src/*"]
    }
  },
  "include": ["app", "modules", "utils", "next-env.d.ts", "*.ts", "*.tsx"],
  "exclude": ["node_modules"]
}
