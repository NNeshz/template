{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"],
      "@app/web": ["../../apps/web"],
      "@app/web/*": ["../../apps/web/*"],
      "@app/docs": ["../../apps/docs"],
      "@app/docs/*": ["../../apps/docs/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
