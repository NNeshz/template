# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8080

# Origins (backend URL also used as Better Auth base URL)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_WWW=https://www.yourdomain.com   # opcional — dejar vacío en desarrollo

# Cookie domain (producción: ".yourdomain.com" — incluir el punto inicial)
# En desarrollo dejar vacío
COOKIE_DOMAIN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
