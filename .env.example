# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FRONTEND=http://localhost:3000
NEXT_PUBLIC_BACKEND=http://localhost:8080

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ─── Better Auth ──────────────────────────────────────────────────────────────
